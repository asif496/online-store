# ── Database (Railway MySQL) ──────────────────────────────
DB_HOST=your-railway-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASS=your_railway_db_password
DB_NAME=railway
DB_SSL=true

# ── Server ─────────────────────────────────────────────────
# Render assigns PORT automatically — do not hard-code it
PORT=10000
NODE_ENV=production

# ── URLs ───────────────────────────────────────────────────
# Your deployed frontend URL (from Vercel)
FRONTEND_ORIGIN=https://your-project.vercel.app

# Your deployed backend URL (from Render)
BACKEND_URL=https://your-backend.onrender.com
